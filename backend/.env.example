# Copie para backend/.env e ajuste se necessario
DATABASE_URL=postgresql://SEU_USUARIO:SUA_SENHA@SEU_HOST:5432/SEU_BANCO?sslmode=require

# Opcional: usado apenas se DATABASE_URL nao estiver definido
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Opcional: frontend(s) autorizados para chamadas da API
CORS_ALLOW_ORIGINS=https://maerainhavencedora.com.br,https://www.maerainhavencedora.com.br

# Opcional: URL publica canonical para links (ex.: compartilhamento/QR)
PUBLIC_BASE_URL=https://app.maerainhavencedora.com.br

# Opcional: duracao da sessao de login em dias (1-365)
AUTH_SESSION_DAYS=30

# Opcional: fallback de identificacao de tom por API (Spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Opcional: caminhos para fallback local em JSON quando DATABASE_URL nao estiver definido
# Defaults:
# - <raiz-do-projeto>/data/song_favorites.json
# - <raiz-do-projeto>/data/custom_songs.json
# - <raiz-do-projeto>/data/mystery_song_assignments.json
SONG_FAVORITES_FILE=
CUSTOM_SONGS_FILE=
MYSTERY_SONG_ASSIGNMENTS_FILE=

# Opcional: senha adicional para inativar itens globais da arvore de locais
SONG_LOCATION_DELETE_PASSWORD=

# Opcional: validade de links de compartilhamento (horas)
SONG_SHARE_TTL_HOURS=168

# Opcional: limite de requisições por IP na janela abaixo
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_REQUESTS=240
RATE_LIMIT_WRITE_REQUESTS=80
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_SHARE_REQUESTS=45

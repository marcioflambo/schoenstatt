# Copie para backend/.env e ajuste se necessario
DATABASE_URL=postgresql://SEU_USUARIO:SUA_SENHA@SEU_HOST:5432/SEU_BANCO?sslmode=require

# Opcional: usado apenas se DATABASE_URL nao estiver definido
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Opcional: frontend(s) autorizados para chamadas da API
CORS_ALLOW_ORIGINS=*

# Opcional: caminho do arquivo JSON local para favoritos
# Default: <raiz-do-projeto>/tmp/song_favorites.json
SONG_FAVORITES_FILE=
